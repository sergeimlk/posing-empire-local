# Ignore video files in symlinked directories
public/content/**/*.mp4
public/content/**/*.mov
public/content/**/*.webm
public/content/**/*.avi
public/content/**/*.part
public/content/**/*.ytdl

# Ignore Python dependencies and virtual environments
.venv/
__pycache__/
*.pyc

# Ignore local config files
.env.local
.env.*.local
